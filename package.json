{
  "name": "pixel-mav",
  "displayName": "Pixel Mav",
  "description": "Watch your Claude Code agents come to life as animated pixel art cats",
  "version": "0.1.0",
  "publisher": "harshpujari",
  "repository":"https://github.com/harshpujari/pixel-mav",
  "icon":"",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Education"
  ],
  "keywords": [
    "claude",
    "agent",
    "pixel art",
    "cats",
    "vibe coding",
    "pet",
    "companion"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixel-mav.showPanel",
        "title": "Pixel Mav: Show Panel"
      },
      {
        "command": "pixel-mav.debugSimulate",
        "title": "Pixel Mav: Debug — Simulate Agent Lifecycle"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pixel-mav-panel",
          "title": "Pixel Mav",
          "icon": "media/cat-curled-svgrepo-com.svg" 
        }
      ]
    },
    "views": {
      "pixel-mav-panel": [
        {
          "type": "webview",
          "id": "pixel-mav.panelView",
          "name": "Pixel Mav"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:esbuild watch:tsc",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
